{
  "name": "ti-wiki",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "db:migrate": "tsx scripts/db/migrate.ts",
    "db:refresh": ".venv/bin/python3 scripts/crawler/refresh.py",
    "db:refresh-player-avatars": "tsx scripts/refresh-player-avatars.ts",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "npm run test:server && npm run test:crawler",
    "test:crawler": ".venv/bin/python3 -m unittest discover -s scripts/crawler/tests -p 'test_*.py'",
    "test:server": "tsx --test server/tests/**/*.test.ts"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@vercel/speed-insights": "^2.0.0",
    "better-sqlite3": "^12.10.1",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.8",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.3"
  }
}
