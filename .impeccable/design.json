  "narrative": {
    "northStar": "The Trophy Vault（奖杯陈列馆）",
    "overview": "这个系统是一座冷光下的奖杯陈列馆。每一届 TI 的冠军、奖金、排名、中国战绩都是被托住、被照亮、被安静陈述的展品。界面是展柜的玻璃与射灯：克制、内行、有判断力。数字本身有分量，系统的职责是把数字托住，而不是替数字呐喊。审美哲学是数据即叙事：收敛色板（暗色+一金+一红），克制装饰（几乎不用阴影，靠色阶分层），把视觉重量让给数据排版。明确拒绝 SaaS landing 套路、普通 wiki 丑、臃肿电竞门户、商业彩媒。",
    "keyCharacteristics": [
      "暗色为底（obsidian-void），三段色阶分层（void/panel/subtle），几乎不用阴影",
      "一金（不朽盾金）一红（朱砂信号）双强调，金主红辅，用得稀才有力",
      "数据排版优先：等宽数字、黑体大字编号、信息密度高于装饰",
      "移动优先单列，桌面 max 1200 分栏，表格横向滚动不拆碎",
      "沉浸但克制：入场/揭示动效允许，但每段服务于让某事实被看见，永不闪烁/发光泛滥"
    ],
    "rules": [
      { "name": "The One Spotlight Rule", "body": "不朽盾金是唯一的射灯。任何屏幕金色面积 ≤10%。冠军值得金，亚军以下不得镀金。金色泛滥=奖杯贬值。", "section": "colors" },
      { "name": "The Crimson Single-Meaning Rule", "body": "朱砂信号只标记中国。不用于错误态、不用于警告、不用于普通强调。看到朱砂=在讲中国战队。", "section": "colors" },
      { "name": "The Tonal-Only Depth Rule", "body": "纵深只靠 void→panel→subtle 三段色阶传达。默认无阴影。卡片是更亮的暗格，不是浮起的物体。", "section": "elevation" },
      { "name": "The Weight-Not-Family Rule", "body": "层级靠字重+字号跨度（≥1.25 比率），不靠第二个字族。display 900 与 body 400 的跨度就是层级。", "section": "typography" },
      { "name": "The Numbers-Mono Rule", "body": "所有奖金、百分比、名次编号用等宽。数字对齐=数据面板的专业感。", "section": "typography" },
      { "name": "The Flat-At-Rest Rule", "body": "静态表面一律扁平。阴影是状态语言（浮起/固定），不是装饰语言。", "section": "elevation" },
      { "name": "The Border-Not-Shadow Rule", "body": "hover/聚焦反馈用边框色变（→不朽盾金 60% 透明），不用投影。避免 ghost-card 套路。", "section": "elevation" }
    ],
    "dos": [
      "Do 把不朽盾金用在冠军、奖金、主 CTA 上，单屏 ≤10%",
      "Do 用等宽字体排奖金与名次，让数字对齐成面板",
      "Do 用 void/panel/subtle 三段色阶分层，纵深靠亮度差不靠阴影",
      "Do hover 反馈用边框转金（gold/60），不用投影",
      "Do 中国战队用 🇨🇳 emoji + 朱砂 chip 双通道标识",
      "Do 表格移动端横向滚动，保留完整列结构",
      "Do 所有动效在 prefers-reduced-motion: reduce 下退化为即时/淡入"
    ],
    "donts": [
      "Don't 滥用金色——亚军及以下不得镀金",
      "Don't 用朱砂信号标记非中国内容",
      "Don't 给卡片加侧色条（border-left/right >1px 彩条）",
      "Don't 做玻璃卡片堆——backdrop-blur 仅极克制使用",
      "Don't 做 SaaS landing 套路：大渐变 hero、emoji 当核心图标、轮播证言",
      "Don't 做臃肿电竞门户：荧光色、闪烁文字、动画乱跳",
      "Don't 配 1px solid border + box-shadow blur ≥16px（ghost-card）",
      "Don't 卡片圆角 ≥24px——封顶 12–16px",
      "Don't 用 gradient text——单色，靠字重/字号做强调"
    ]
  }
}
